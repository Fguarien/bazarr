services:
  bazarr:
    image: ghcr.io/linuxserver/bazarr
    container_name: bazarr
    environment:
      - PUID=1026
      - PGID=100
      - TZ=Europe/Brussels
    volumes:
      - /volume1/docker/bazarr:/config
      - "/volume1/Media/Movies:/movies:rw"
      - "/volume1/Media/TV Shows:/tv:rw"
    ports:
      - "6767:6767"
    restart: always
    mem_limit: 12g
    mem_reservation: 2g
  radarr:
    image: lscr.io/linuxserver/radarr
    container_name: radarr
    environment:
      - PUID=1026
      - PGID=100
      - TZ=Europe/Brussels
    volumes:
      - /volume1/docker/radarr:/config
      - /volume1/downloads:/downloads
      - "/volume1/Media/Movies:/movies:rw"
    ports:
      - "7878:7878"
    restart: always
    mem_limit: 12g
    mem_reservation: 2g
  sonarr:
    image: lscr.io/linuxserver/sonarr
    container_name: sonarr
    environment:
      - PUID=1026
      - PGID=100
      - TZ=Europe/Brussels
    volumes:
      - /volume1/docker/sonarr:/config
      - /volume1/downloads:/downloads
      - "/volume1/Media/TV Shows:/tv:rw"
    ports:
      - "8989:8989"
    restart: always
    mem_limit: 12g
    mem_reservation: 2g
  jackett:
    image: ghcr.io/linuxserver/jackett
    container_name: jackett
    environment:
      - AUTO_UPDATE=true
      - PUID=1026
      - PGID=100
      - TZ=Europe/Bucharest
    volumes:
      - /volume1/docker/jackett/config:/config
      - /volume1/docker/jackett/downloads:/downloads
    ports:
      - 9117:9117
    restart: always
    mem_limit: 12g
    mem_reservation: 2g
  lidarr:
    image: lscr.io/linuxserver/lidarr
    container_name: lidarr
    environment:
      - PUID=1026
      - PGID=100
      - TZ=Europe/Brussels
    volumes:
      - /volume1/docker/lidarr/config:/config
      - /volume1/music/organized:/music
      - /volume1/music/deleted:/trashed
      - /volume1/downloads:/downloads
    ports:
      - "8686:8686"
    restart: always
    mem_limit: 12g
    mem_reservation: 2g
